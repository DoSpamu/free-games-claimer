# ============================================================
#  free-games-claimer – przykładowy plik konfiguracyjny
#  Skopiuj do: data/config.env  lub  przekaż jako env w docker-compose
# ============================================================

# ------ Scheduler ------
CRON_SCHEDULE=0 7 * * *      # kiedy uruchamiać (domyślnie codziennie o 07:00)
TZ=Europe/Warsaw              # strefa czasowa dla crona
RUN_ON_START=0                # 1 = uruchom od razu po starcie kontenera
HEALTH_PORT=8080              # port dla /health i POST /run
LOG_LEVEL=INFO                # DEBUG | INFO | WARN | ERROR

# ------ Discord webhook ------
DISCORD_WEBHOOK=https://discord.com/api/webhooks/TWOJE_ID/TWOJ_TOKEN

# ------ Apprise (istniejące powiadomienia) ------
# NOTIFY=tgram://bottoken/chatid
# NOTIFY_TITLE=Free Games Claimer

# ------ Dane logowania ------
# EMAIL=twoj@email.com
# PASSWORD=twoje_haslo

# Epic Games
# EG_EMAIL=
# EG_PASSWORD=
# EG_OTPKEY=

# Prime Gaming
# PG_EMAIL=
# PG_PASSWORD=
# PG_OTPKEY=
# PG_REDEEM=0

# GOG
# GOG_EMAIL=
# GOG_PASSWORD=

# Steam
# STEAM_USERNAME=
# STEAM_PASSWORD=

# ------ Wyświetlanie / VNC ------
SHOW=1
WIDTH=1920
HEIGHT=1080
# VNC_PASSWORD=
