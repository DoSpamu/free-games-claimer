# ============================================================
#  free-games-claimer — przykładowy plik konfiguracyjny
#  Skopiuj do: data/config.env  lub przekaż jako env w docker-compose
# ============================================================

# ------ Logowanie ------
LOG_LEVEL=INFO                 # DEBUG | INFO | WARN | ERROR

# ------ Discord webhook ------
DISCORD_WEBHOOK=https://discord.com/api/webhooks/TWOJE_ID/TWOJ_TOKEN

# ------ Apprise (alternatywne / dodatkowe powiadomienia) ------
# NOTIFY=tgram://bottoken/chatid
# NOTIFY_TITLE=Free Games Claimer

# ------ VNC ------
SHOW=1
WIDTH=1920
HEIGHT=1080
VNC_PASSWORD=tajnehaslo        # zalecane — bez hasła noVNC jest otwarte na sieć!

# ------ Dane logowania ------
# EMAIL=twoj@email.com
# PASSWORD=haslo

# Epic Games
# EG_EMAIL=
# EG_PASSWORD=
# EG_OTPKEY=

# Prime Gaming
# PG_EMAIL=
# PG_PASSWORD=
# PG_OTPKEY=
# PG_REDEEM=0

# GOG
# GOG_EMAIL=
# GOG_PASSWORD=

# Steam
# STEAM_USERNAME=
# STEAM_PASSWORD=
