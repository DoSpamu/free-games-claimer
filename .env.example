# ============================================================
#  free-games-claimer — przykładowy plik konfiguracyjny
#  Skopiuj do: data/config.env  lub przekaż jako env w docker-compose
# ============================================================

# ------ Scheduler ------
CRON_SCHEDULE=0 7 * * *       # kiedy uruchamiać (domyślnie codziennie o 07:00)
TZ=Europe/Warsaw               # strefa czasowa dla crona
RUN_ON_START=0                 # 1 = uruchom od razu po starcie kontenera
RETRY_FAILED=1                 # 1 = ponów nieudane platformy po 30 min
WEEKLY_DIGEST=1                # 1 = tygodniowe podsumowanie Discord (niedziela 10:00)
HEALTH_PORT=8080               # port dla /health i POST /run
LOG_LEVEL=INFO                 # DEBUG | INFO | WARN | ERROR

# ------ Platformy (0 = wyłączona) ------
CLAIM_STEAM=1
CLAIM_EPIC=1
CLAIM_PRIME=1
CLAIM_GOG=1

# ------ Discord webhook ------
DISCORD_WEBHOOK=https://discord.com/api/webhooks/TWOJE_ID/TWOJ_TOKEN

# ------ Apprise (alternatywne / dodatkowe powiadomienia) ------
# NOTIFY=tgram://bottoken/chatid
# NOTIFY_TITLE=Free Games Claimer

# ------ VNC ------
SHOW=1
WIDTH=1920
HEIGHT=1080
VNC_PASSWORD=tajnehaslo        # zalecane — bez hasła noVNC jest otwarte na sieć!

# ------ Dane logowania ------
# EMAIL=twoj@email.com
# PASSWORD=haslo

# Epic Games
# EG_EMAIL=
# EG_PASSWORD=
# EG_OTPKEY=

# Prime Gaming
# PG_EMAIL=
# PG_PASSWORD=
# PG_OTPKEY=
# PG_REDEEM=0

# GOG
# GOG_EMAIL=
# GOG_PASSWORD=

# Steam
# STEAM_USERNAME=
# STEAM_PASSWORD=
